# Shared Firebase / Identity Platform (all dev modes). Copy to .env and fill in.
# API key from Secret Manager (referrer-restricted; includes http://localhost:5173/*):
#   gcloud secrets versions access latest \
#     --secret=tripplanning-firebase-web-api-key --project=tbd-cloudappdev
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=tbd-cloudappdev.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=tbd-cloudappdev

# Maps JavaScript API + Routes API (browser key, HTTP referrer–restricted).
# NOT the same as backend GOOGLE_MAPS_API_KEY (Places, server-side).
# GCP: enable routes.googleapis.com + maps-backend.googleapis.com on the key.
# Application restrictions → HTTP referrers (websites), include for local dev:
#   http://localhost:5173/*
#   http://127.0.0.1:5173/*
# VITE_GOOGLE_MAPS_API_KEY=

# --- Dev API proxy (pick one npm script; do not need all of these in .env) ---

# npm run dev:k8s  → uses .env.k8s (GKE Gateway, HTTPS)
# npm run dev:minikube → uses .env.minikube (localhost:8080 after port-forward)

# npm run dev — uses .env.development (trip :8080, social :8081, external :8082, platform :8083)
# Override only if needed:
# VITE_API_BASE_URL=
# VITE_DEV_API_PROXY_TARGET=http://localhost:8080
# VITE_DEV_SOCIAL_PROXY_TARGET=http://localhost:8081
# VITE_DEV_EXTERNAL_PROXY_TARGET=http://localhost:8082
# VITE_DEV_PLATFORM_PROXY_TARGET=http://localhost:8083

# Production build (no proxy): leave empty for same-origin /api/v2 on GKE (recommended).
# VITE_API_BASE_URL=
#
# Only set a full API origin when
# the SPA and API are on different hosts and you accept cross-origin requests, e.g.:
# VITE_API_BASE_URL=https://api.paas-dev.tbd-htwg.de
