# API base URL (no trailing slash). Leave unset or empty for same-origin /api/v2
# (Vite dev proxy locally; Caddy -> backend container in infrastructure).
# Set to e.g. http://localhost:8080/api/v2 only if you are not using the dev proxy.
# VITE_API_BASE_URL=

# Google Identity Services (Sign in with Google) — OAuth 2.0 Web client ID from Google Cloud Console.
# Add http://localhost:5173 (and http://127.0.0.1:5173 if needed) under Authorized JavaScript origins.
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
#
# CI: add repository or environment Actions secret TRIPPLANNING_AUTH_GOOGLE_CLIENT_ID (same Web client ID
# as the backend) so deploy-gcp-cloudrun.yml can bake it into .env.production at build time.
