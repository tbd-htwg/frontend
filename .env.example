# API base URL (no trailing slash). Leave unset or empty for same-origin /api/v2
# (Vite dev proxy locally; Caddy -> backend container in infrastructure).
# Set to e.g. http://localhost:8080/api/v2 only if you are not using the dev proxy.
# VITE_API_BASE_URL=

# Firebase / Identity Platform — Web app values from Firebase console (Project settings).
# Must match the GCP project used by trip-service TRIPPLANNING_AUTH_FIREBASE_PROJECT_ID
# (K8s: trip-service-config ConfigMap). See infrastructure/ms2/docs/gettingstarted/README.md § Identity.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=milestone2-tbd-cad.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=milestone2-tbd-cad
