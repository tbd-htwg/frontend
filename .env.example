# Shared Firebase / Identity Platform (all dev modes). Copy to .env and fill in.
# Firebase console → Project settings → Your apps → Web app config.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=milestone2-tbd-cad.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=milestone2-tbd-cad

# --- Dev API proxy (pick one npm script; do not need all of these in .env) ---

# npm run dev:k8s  → uses .env.k8s (GKE Gateway, HTTPS)
# npm run dev:minikube → uses .env.minikube (localhost:8080 after port-forward)

# npm run dev (plain vite) — defaults proxy to http://localhost:8080 (see vite.config.ts)
# Override only if needed:
# VITE_API_BASE_URL=
# VITE_DEV_API_PROXY_TARGET=http://localhost:8080

# Production build (no proxy): set full API origin, e.g.:
# VITE_API_BASE_URL=https://api.k8s.tbd-htwg.de
