# npm run dev against GKE: leave VITE_API_BASE_URL empty; Vite proxies to VITE_DEV_API_PROXY_TARGET.
VITE_API_BASE_URL=
VITE_DEV_API_PROXY_TARGET=http://api.k8s.tbd-htwg.de

# Production build (or direct API without proxy): set full API origin, e.g.:
# VITE_API_BASE_URL=http://api.k8s.tbd-htwg.de

# Firebase / Identity Platform — Web app values from Firebase console (Project settings).
# Must match TRIPPLANNING_AUTH_FIREBASE_PROJECT_ID on trip-service.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=milestone2-tbd-cad.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=milestone2-tbd-cad
