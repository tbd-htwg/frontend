    "components": {
        "schemas": {
            "UserPutRequest": {
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string",
                        "example": "jane.doe@example.com",
                        "minLength": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Jane Doe",
                        "maxLength": 255,
                        "minLength": 0
                    }
                },
                "required": [
                    "email",
                    "name"
                ]
            },
            "UserResponse": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64",
                        "example": 1
                    },
                    "email": {
                        "type": "string",
                        "example": "jane.doe@example.com"
                    },
                    "name": {
                        "type": "string",
                        "example": "Jane Doe"
                    }
                }
            },
            "TripPutRequest": {
                "type": "object",
                "properties": {
                    "userId": {
                        "type": "integer",
                        "format": "int64",
                        "example": 1
                    },
                    "title": {
                        "type": "string",
                        "example": "Family trip to Norway",
                        "maxLength": 255,
                        "minLength": 0
                    },
                    "destination": {
                        "type": "string",
                        "example": "Bergen",
                        "maxLength": 255,
                        "minLength": 0
                    },
                    "startDate": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-08-01"
                    },
                    "shortDescription": {
                        "type": "string",
                        "example": "Coastal road trip",
                        "maxLength": 80,
                        "minLength": 0
                    },
                    "longDescription": {
                        "type": "string",
                        "example": "Updated route, hotels, and activities.",
                        "minLength": 1
                    }
                },
                "required": [
                    "destination",
                    "longDescription",
                    "shortDescription",
                    "startDate",
                    "title",
                    "userId"
                ]
            },
            "TripDetailsResponse": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64",
                        "example": 42
                    },
                    "title": {
                        "type": "string",
                        "example": "Family trip to Norway"
                    },
                    "destination": {
                        "type": "string",
                        "example": "Oslo"
                    },
                    "startDate": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-07-15"
                    },
                    "shortDescription": {
                        "type": "string",
                        "example": "Summer holiday with the kids"
                    },
                    "longDescription": {
                        "type": "string",
                        "example": "Full itinerary, budget notes, and packing list."
                    }
                }
            },
            "UserCreateRequest": {
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string",
                        "example": "jane.doe@example.com",
                        "minLength": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Jane Doe",
                        "maxLength": 255,
                        "minLength": 0
                    }
                },
                "required": [
                    "email",
                    "name"
                ]
            },
            "TripCreateRequest": {
                "type": "object",
                "properties": {
                    "userId": {
                        "type": "integer",
                        "format": "int64",
                        "example": 1
                    },
                    "title": {
                        "type": "string",
                        "example": "Family trip to Norway",
                        "maxLength": 255,
                        "minLength": 0
                    },
                    "destination": {
                        "type": "string",
                        "example": "Oslo",
                        "maxLength": 255,
                        "minLength": 0
                    },
                    "startDate": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-07-15"
                    },
                    "shortDescription": {
                        "type": "string",
                        "example": "Summer holiday with the kids",
                        "maxLength": 80,
                        "minLength": 0
                    },
                    "longDescription": {
                        "type": "string",
                        "example": "Full itinerary, budget notes, and packing list.",
                        "minLength": 1
                    }
                },
                "required": [
                    "destination",
                    "longDescription",
                    "shortDescription",
                    "startDate",
                    "title",
                    "userId"
                ]
            },
            "UserPatchRequest": {
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string",
                        "example": "jane.new@example.com"
                    },
                    "name": {
                        "type": "string",
                        "example": "Jane D.",
                        "maxLength": 255,
                        "minLength": 0
                    }
                }
            },
            "TripPatchRequest": {
                "type": "object",
                "properties": {
                    "userId": {
                        "type": "integer",
                        "format": "int64",
                        "example": 2
                    },
                    "title": {
                        "type": "string",
                        "example": "Renamed trip title",
                        "maxLength": 255,
                        "minLength": 0
                    },
                    "destination": {
                        "type": "string",
                        "example": "Trondheim",
                        "maxLength": 255,
                        "minLength": 0
                    },
                    "startDate": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-09-10"
                    },
                    "shortDescription": {
                        "type": "string",
                        "example": "New subtitle",
                        "maxLength": 80,
                        "minLength": 0
                    },
                    "longDescription": {
                        "type": "string",
                        "example": "Only fields you send are updated."
                    }
                }
            },
            "TripListItemResponse": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64",
                        "example": 42
                    },
                    "title": {
                        "type": "string",
                        "example": "Family trip to Norway"
                    },
                    "startDate": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-07-15"
                    }
                }
            },
            "UserDetailsResponse": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64",
                        "example": 1
                    },
                    "email": {
                        "type": "string",
                        "example": "jane.doe@example.com"
                    },
                    "name": {
                        "type": "string",
                        "example": "Jane Doe"
                    },
                    "trips": {
                        "type": "array",
                        "description": "Trips owned by this user",
                        "items": {
                            "$ref": "#/components/schemas/TripListItemResponse"
                        }
                    }
                }
            }
        }
    }
