# npm run dev:k8s — trip/social/external via GKE Gateway (HTTPS). Platform defaults to localhost:8083.
# When platform is on the gateway, set: VITE_DEV_PLATFORM_PROXY_TARGET=https://k8s.tbd-htwg.de
# Requires k8s.tbd-htwg.de reachable (DNS, TLS). Firebase: set VITE_FIREBASE_* in .env.
VITE_API_BASE_URL=
VITE_DEV_API_PROXY_TARGET=https://k8s.tbd-htwg.de
