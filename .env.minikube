# npm run dev:minikube — trip/social/external via ingress port-forward (:8080).
# Platform-service (auth/admin) is not on minikube ingress; defaults to :8083 (JVM or separate forward).
# Run from backend/: ./scripts/local-dev.sh port-forward
# Firebase: set VITE_FIREBASE_* in .env (optional for dev-login only).
VITE_API_BASE_URL=
VITE_DEV_API_PROXY_TARGET=http://localhost:8080
